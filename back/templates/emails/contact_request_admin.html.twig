<!doctype html>
<html lang="fr">
  <body style="margin:0;padding:0;background:#e9e3d8;background-image:linear-gradient(180deg,#e9e3d8 0%,#f4efe7 45%,#efe7db 100%);font-family:Inter,Arial,sans-serif;color:#2b2b2b;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="padding:28px 12px;">
      <tr>
        <td align="center">
          <table role="presentation" width="680" cellpadding="0" cellspacing="0" style="max-width:680px;background:#ffffff;border:1px solid rgba(120,96,56,0.16);border-radius:22px;overflow:hidden;box-shadow:0 20px 44px rgba(63,92,110,0.16);">
            <tr>
              <td style="padding:18px 24px;background:#a8842f;background-image:linear-gradient(120deg,#fff6d5 0%,#f1d27a 35%,#d4af37 70%,#a8842f 100%);color:#2b2b2b;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                  <tr>
                    <td valign="top" style="width:102px;padding:0 16px 0 0;">
                      <img src="https://lueur-eternite.fr/assets/logo_full.webp" alt="{{ siteName }}" width="82" style="display:block;height:auto;" />
                    </td>
                    <td valign="top" style="padding:0;">
                      <p style="margin:0;font-size:12px;letter-spacing:.12em;text-transform:uppercase;opacity:.88;">Formulaire de contact</p>
                      <h1 style="margin:6px 0 0;font-family:'Playfair Display',Georgia,serif;font-size:30px;line-height:1.22;font-weight:500;">Nouvelle demande client</h1>
                      <p style="margin:8px 0 0;font-size:14px;opacity:.94;">{{ siteName }}</p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
            <tr>
              <td style="padding:24px 24px 10px;">
                <p style="margin:0 0 16px;font-size:15px;line-height:1.6;">
                  Une nouvelle demande vient d’être envoyée depuis le site. Voici le récapitulatif.
                </p>
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                  <tr>
                    <td style="padding:0 0 10px;">
                      <span style="display:inline-block;padding:8px 12px;border-radius:999px;background:#f4efe7;border:1px solid rgba(120,96,56,0.16);font-size:13px;">
                        <strong>Nom :</strong> {{ fullName }}
                      </span>
                    </td>
                  </tr>
                  <tr>
                    <td style="padding:0 0 10px;">
                      <span style="display:inline-block;padding:8px 12px;border-radius:999px;background:#f4efe7;border:1px solid rgba(120,96,56,0.16);font-size:13px;">
                        <strong>Email :</strong> <a href="mailto:{{ senderEmail }}" style="color:#3f5c6e;text-decoration:none;">{{ senderEmail }}</a>
                      </span>
                    </td>
                  </tr>
                  <tr>
                    <td style="padding:0 0 8px;">
                      <span style="display:inline-block;padding:8px 12px;border-radius:999px;background:#f4efe7;border:1px solid rgba(120,96,56,0.16);font-size:13px;">
                        <strong>Téléphone :</strong> {{ phone }}
                      </span>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
            <tr>
              <td style="padding:10px 24px 4px;">
                <div style="height:1px;background:linear-gradient(90deg,rgba(212,175,55,0),rgba(212,175,55,0.85),rgba(212,175,55,0));"></div>
              </td>
            </tr>
            <tr>
              <td style="padding:16px 24px 10px;">
                <h2 style="margin:0 0 10px;font-family:'Playfair Display',Georgia,serif;font-size:21px;font-weight:500;color:#2b2b2b;">Message</h2>
                <div style="padding:16px;border:1px solid rgba(120,96,56,0.16);border-radius:14px;background:linear-gradient(180deg,rgba(255,251,247,0.95),rgba(244,237,228,0.82));white-space:pre-line;line-height:1.7;font-size:14px;">
                  {{ message }}
                </div>
              </td>
            </tr>
            <tr>
              <td style="padding:16px 24px 24px;">
                <a href="mailto:{{ senderEmail }}" style="display:inline-block;padding:11px 18px;border-radius:999px;background:linear-gradient(120deg,#f1d27a 0%,#d4af37 55%,#a8842f 100%);color:#fffaf0;text-decoration:none;font-weight:600;font-size:13px;letter-spacing:.01em;">
                  Répondre à {{ fullName }}
                </a>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
