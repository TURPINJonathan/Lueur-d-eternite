APP_ENV=prod
APP_DEBUG=0

# URLs publiques
BACK_URL=https://api.example.com
FRONT_URL=https://www.example.com
DEFAULT_URI=https://api.example.com

# Symfony
DATABASE_URL=mysql://user:password@127.0.0.1:3306/elixir_linge?serverVersion=mariadb-10.11.2&charset=utf8mb4
MAILER_DSN=smtp://user:password@smtp.example.com:587
MESSENGER_TRANSPORT_DSN=doctrine://default
JWT_PASSPHRASE=change-me-very-strong-passphrase

# Optionnel (sinon généré automatiquement)
# APP_SECRET=
# MEDIA_ENCRYPTION_KEY=
# CORS_ALLOW_ORIGIN='^https?://www\.example\.com(:[0-9]+)?$'

# Optionnel: créer un super admin automatiquement
CREATE_SUPER_ADMIN=0
# ADMIN_FIRSTNAME=Admin
# ADMIN_LASTNAME=Root
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change-me

# Optionnel
FORCE_JWT_REGEN=0
RUN_HEALTHCHECKS=1

# Optionnel: installation services systemd (Linux)
SETUP_SYSTEMD=0
DEPLOY_USER=www-data
SYSTEMD_FRONT_SERVICE_NAME=lueur-front
SYSTEMD_MESSENGER_SERVICE_NAME=lueur-messenger
